# CLAWD Agent Launcher — Environment Variables
# Copy this to .env and fill in your values

# ---- Required for LLM Gateway ----
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Gateway secret — protects the key creation endpoint
# Generate a random string: openssl rand -hex 32
GATEWAY_SECRET=your-gateway-secret

# ---- Required for CLAWD burn (Phase 2+) ----
# Base mainnet RPC URL (Alchemy, Infura, etc.)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key

# Private key of wallet that holds CLAWD for burning
# WARNING: Never commit this value!
BURNER_PRIVATE_KEY=0x...

# ---- Frontend ----
# URL of the API gateway
NEXT_PUBLIC_API_URL=http://localhost:3001
